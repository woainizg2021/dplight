[Unit]
Description=Dplight ERP Backend Service
After=network.target

[Service]
User=root
Group=root
WorkingDirectory=/opt/dplight/backend
Environment="PATH=/opt/dplight/backend/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin"
EnvironmentFile=/opt/dplight/.env
ExecStart=/opt/dplight/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 4

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
