# 这是环境变量示例文件（.env.example）
# 注意：不要在此文件中填写真实密钥并提交到 Git
# 本地开发可复制为 .env 使用（后续将接入 python-dotenv 加载）

# 已迁移变量（样板）
AI_API_KEY=
WA_ACCESS_TOKEN=

# 后续计划迁移的常用变量（占位符）
WA_VERIFY_TOKEN=
SHARED_DB_HOST=
SHARED_DB_PORT=
SHARED_DB_USER=
SHARED_DB_PASSWORD=
SHARED_DB_DATABASE=

# ERP 主机
ERP_HOST=
ERP_PORT=

# ERP 凭证（示例）
ERP_UGANDA_USER=
ERP_UGANDA_PASS=
ERP_NIGERIA_USER=
ERP_NIGERIA_PASS=
ERP_KENYA_USER=
ERP_KENYA_PASS=
ERP_DRC_USER=
ERP_DRC_PASS=
ERP_KENYA_AUDIO_USER=
ERP_KENYA_AUDIO_PASS=
